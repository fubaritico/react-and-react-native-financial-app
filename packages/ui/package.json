{
  "name": "@financial-app/ui",
  "version": "1.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "default": "./src/index.web.ts"
    }
  },
  "react-native": "./src/index.ts",
  "private": true,
  "scripts": {
    "changelog": "conventional-changelog -p angular -r 0 --path . > CHANGELOG.md",
    "build": "tsc --noEmit",
    "lint": "eslint ./src",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-native": "catalog:"
  },
  "dependencies": {
    "@financial-app/tailwind-config": "workspace:^",
    "@financial-app/tokens": "workspace:^",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "twrnc": "catalog:"
  },
  "devDependencies": {
    "@storybook/react-native-web-vite": "catalog:",
    "@types/react": "catalog:",
    "autoprefixer": "catalog:",
    "conventional-changelog": "catalog:",
    "postcss": "catalog:",
    "react-dom": "catalog:",
    "react-native-web": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
