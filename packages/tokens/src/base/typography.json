{
  "font": {
    "family": {
      "$description": "Font family stacks",
      "sans": { "$value": "'Public Sans', ui-sans-serif, system-ui, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'", "$type": "fontFamily" }
    },
    "size": {
      "$description": "Font size scale matching Figma text presets",
      "xs": { "$value": "0.75rem", "$type": "dimension" },
      "sm": { "$value": "0.875rem", "$type": "dimension" },
      "base": { "$value": "1rem", "$type": "dimension" },
      "lg": { "$value": "1.125rem", "$type": "dimension" },
      "xl": { "$value": "1.25rem", "$type": "dimension" },
      "2xl": { "$value": "1.5rem", "$type": "dimension" },
      "3xl": { "$value": "1.875rem", "$type": "dimension" },
      "4xl": { "$value": "2rem", "$type": "dimension" }
    },
    "weight": {
      "$description": "Font weight scale",
      "normal": { "$value": "400", "$type": "fontWeight" },
      "bold": { "$value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "$description": "Line height scale matching Figma presets",
      "tight": { "$value": "1.2", "$type": "number" },
      "normal": { "$value": "1.5", "$type": "number" }
    }
  },
  "textPreset": {
    "$description": "Composite text presets from Figma design system",
    "1": {
      "fontSize": { "$value": "2rem", "$type": "dimension" },
      "lineHeight": { "$value": "1.2", "$type": "number" },
      "fontWeight": { "$value": "700", "$type": "fontWeight" }
    },
    "2": {
      "fontSize": { "$value": "1.25rem", "$type": "dimension" },
      "lineHeight": { "$value": "1.2", "$type": "number" },
      "fontWeight": { "$value": "700", "$type": "fontWeight" }
    },
    "3": {
      "fontSize": { "$value": "1rem", "$type": "dimension" },
      "lineHeight": { "$value": "1.5", "$type": "number" },
      "fontWeight": { "$value": "700", "$type": "fontWeight" }
    },
    "4": {
      "fontSize": { "$value": "0.875rem", "$type": "dimension" },
      "lineHeight": { "$value": "1.5", "$type": "number" },
      "fontWeight": { "$value": "400", "$type": "fontWeight" }
    },
    "4Bold": {
      "fontSize": { "$value": "0.875rem", "$type": "dimension" },
      "lineHeight": { "$value": "1.5", "$type": "number" },
      "fontWeight": { "$value": "700", "$type": "fontWeight" }
    },
    "5": {
      "fontSize": { "$value": "0.75rem", "$type": "dimension" },
      "lineHeight": { "$value": "1.5", "$type": "number" },
      "fontWeight": { "$value": "400", "$type": "fontWeight" }
    },
    "5Bold": {
      "fontSize": { "$value": "0.75rem", "$type": "dimension" },
      "lineHeight": { "$value": "1.5", "$type": "number" },
      "fontWeight": { "$value": "700", "$type": "fontWeight" }
    }
  }
}
