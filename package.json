{
  "name": "react-and-react-native-financial-app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "------------ EXPO (managed) ------------": "",
    "expo:start": "pnpm --filter mobile-expo-financial-app start",
    "expo:start:clean": "pnpm --filter mobile-expo-financial-app start:clean",
    "expo:ios": "pnpm --filter mobile-expo-financial-app ios",
    "expo:android": "pnpm --filter mobile-expo-financial-app android",
    "expo:ios:device": "pnpm --filter mobile-expo-financial-app ios:build:device",
    "expo:android:device": "pnpm --filter mobile-expo-financial-app android:build:device",
    "expo:prebuild": "pnpm --filter mobile-expo-financial-app prebuild",
    "expo:rebuild:ios": "pnpm --filter mobile-expo-financial-app prebuild && pnpm --filter mobile-expo-financial-app ios",
    "expo:rebuild:android": "pnpm --filter mobile-expo-financial-app prebuild && pnpm --filter mobile-expo-financial-app android",
    "expo:fix": "pnpm --filter mobile-expo-financial-app expo:fix",
    "expo:check": "pnpm --filter mobile-expo-financial-app expo:check",

    "------------ MOBILE (bare RN CLI) ------": "",
    "mobile:start": "pnpm --filter mobile-financial-app start",
    "mobile:start:clean": "pnpm --filter mobile-financial-app start:clean",
    "mobile:ios": "pnpm --filter mobile-financial-app ios",
    "mobile:android": "pnpm --filter mobile-financial-app android",
    "mobile:ios:device": "pnpm --filter mobile-financial-app ios:device",
    "mobile:pods": "pnpm --filter mobile-financial-app pods",
    "mobile:rebuild:ios": "pnpm --filter mobile-financial-app rebuild:ios",
    "mobile:rebuild:android": "pnpm --filter mobile-financial-app rebuild:android",

    "------------ EJECTED (expo ejected) ----": "",
    "ejected:start": "pnpm --filter mobile-expo-ejected-financial-app start",
    "ejected:ios": "pnpm --filter mobile-expo-ejected-financial-app ios:build",
    "ejected:android": "pnpm --filter mobile-expo-ejected-financial-app android:build",

    "------------ WEB ----------------------": "",
    "web:dev": "pnpm --filter web-financial-app dev",

    "------------ TOOLING ------------------": "",
    "build": "turbo build",
    "dev": "turbo dev",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "lint:root": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "turbo test",
    "storybook": "pnpm --filter @financial-app/ui storybook",
    "tokens": "pnpm --filter @financial-app/tokens build",
    "icons": "pnpm --filter @financial-app/icons generate",

    "------------ MAINTENANCE --------------": "",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules",
    "clean:build": "rm -rf packages/*/build packages/*/dist apps/*/dist",
    "reset": "./scripts/reset-project.sh",
    "postinstall": "chmod +x scripts/*.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-native": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"],
    "overrides": {
      "react-native": "0.81.5",
      "@react-native/babel-plugin-codegen": "0.81.5",
      "@react-native/babel-preset": "0.81.5",
      "@react-native/codegen": "0.81.5",
      "@react-native/js-polyfills": "0.81.5",
      "@react-native/metro-babel-transformer": "0.81.5",
      "@react-native/metro-config": "0.81.5"
    }
  }
}
