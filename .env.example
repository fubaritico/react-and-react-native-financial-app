# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Project URL (public)
SUPABASE_URL=https://your-project-id.supabase.co

# Anon Key (public - safe to expose in client apps)
SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (PRIVATE - never expose in client apps, server-side only)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Password (PRIVATE - never commit)
# DB_PASSWORD=your-database-password
