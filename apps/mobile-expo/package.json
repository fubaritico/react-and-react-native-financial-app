{
  "name": "mobile-expo-financial-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "ios:build": "expo run:ios",
    "ios:build:device": "expo run:ios --device",
    "android:build": "expo run:android",
    "android:build:device": "expo run:android --device",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "expo:fix": "npx expo install --fix",
    "expo:check": "npx expo install --check",
    "changelog": "conventional-changelog -p angular -r 0 --path . > CHANGELOG.md",
    "lint": "eslint ./src ./app",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "catalog:",
    "@financial-app/shared": "workspace:^",
    "@financial-app/ui": "workspace:^",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "catalog:",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "catalog:",
    "expo-linking": "~8.0.11",
    "expo-router": "catalog:",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "catalog:",
    "react": "catalog:",
    "react-native": "catalog:",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "conventional-changelog": "catalog:",
    "typescript": "catalog:"
  },
  "private": true
}
